# RIAL AI Backend — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs

# ── Serveur ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Sécurité ─────────────────────────────────────────────
API_SECRET=changez-moi-en-production

# ── Claude AI (Anthropic) ─────────────────────────────────
# Obtenez votre clé sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CinetPay (Mobile Money) ───────────────────────────────
# Obtenez vos clés sur https://cinetpay.com → Tableau de bord → API
CINETPAY_API_KEY=votre-api-key-cinetpay
CINETPAY_SITE_ID=votre-site-id-cinetpay

# ── URLs (redirections après paiement) ───────────────────
BACKEND_URL=https://votre-app.railway.app
FRONTEND_URL=https://votre-dashboard.vercel.app

# ── Google Sheets (optionnel) ─────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=

# ── HubSpot (optionnel) ───────────────────────────────────
HUBSPOT_ACCESS_TOKEN=

# ── Webhooks sortants (optionnel) ─────────────────────────
OUTBOUND_WEBHOOK_URL=
